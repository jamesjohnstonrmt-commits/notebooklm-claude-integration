# ──────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in your real values.
#                  The .env file is git-ignored and must NOT be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Claude / Anthropic ──────────────────────────────────────────────────────
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-opus-4-5

# ── NotebookLM ───────────────────────────────────────────────────────────────
# The Google account you use to log in to notebooklm.google.com
NOTEBOOKLM_EMAIL=your-email@gmail.com
NOTEBOOKLM_PASSWORD=your-google-password

# ── Google Drive ─────────────────────────────────────────────────────────────
# Path to credentials.json downloaded from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client → Desktop app)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Cached OAuth token (created automatically after first login)
GOOGLE_TOKEN_FILE=token.json

# Drive folder ID where generated files will be saved (optional)
# Leave blank to save to the root of My Drive
GOOGLE_DRIVE_FOLDER_ID=

# Drive file IDs for the templates (defaults already set in config.py)
PRESENTATION_TEMPLATE_ID=1UoX6n6ajp9BxtzxgsHgdA078vwz2IOyi
WORKBOOK_TEMPLATE_ID=1v9so1qGI932W2858qW28jJe75S0fD0pL

# ── Output ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
